<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:background="#f34"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <GridLayout
            android:id="@+id/gridLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:alignmentMode="alignMargins"
            android:padding="8dp"
            android:useDefaultMargins="true">

            <!-- Product 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_columnWeight="1"
                android:background="#EEE"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Product 1 - ₹500"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivProduct1"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:contentDescription="Product 1"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img" />
            </LinearLayout>

            <!-- Product 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:background="#EEE"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Product 2 - ₹300"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivProduct2"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:src="@drawable/img"
                    android:scaleType="centerCrop"
                    android:contentDescription="Product 2" />
            </LinearLayout>

            <!-- Product 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:background="#EEE"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Product 3 - ₹600"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivProduct3"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:src="@drawable/img"
                    android:scaleType="centerCrop"
                    android:contentDescription="Product 3" />
            </LinearLayout>



        </GridLayout>
    </LinearLayout>
</ScrollView>
