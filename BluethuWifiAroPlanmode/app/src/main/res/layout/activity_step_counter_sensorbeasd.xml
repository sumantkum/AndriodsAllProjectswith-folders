<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FC"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hi, Sumant!"
            android:textSize="16sp"
            android:textColor="#5F6368"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track Your Move"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A1C2E"
            app:layout_constraintTop_toBottomOf="@id/tvGreeting"
            app:layout_constraintStart_toStartOf="parent" />

        <FrameLayout
            android:id="@+id/progressContainer"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/tvHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                app:indicatorSize="240dp"
                app:trackThickness="14dp"
                android:progress="100"
                app:trackColor="#E8EAED"
                app:trackCornerRadius="10dp" />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/stepProgress"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                app:indicatorSize="240dp"
                app:trackThickness="16dp"
                android:progress="0"
                app:indicatorColor="#6366F1"
                app:trackColor="@android:color/transparent"
                app:trackCornerRadius="10dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="center"
                android:gravity="center">

                <TextView
                    android:id="@+id/stepText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="48sp"
                    android:textColor="#1A1C2E"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STEPS"
                    android:letterSpacing="0.1"
                    android:textSize="12sp"
                    android:textColor="#9AA0A6" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/statsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/progressContainer">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_directions_walk"
                        app:tint="#6366F1"/>
                    <TextView
                        android:id="@+id/distanceText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0 km"
                        android:layout_marginTop="8dp"
                        android:textStyle="bold"
                        android:textSize="18sp"/>
                    <TextView
                        android:text="Distance"
                        android:textSize="12sp"
                        android:textColor="#70757A"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_airplane"
                        app:tint="#F59E0B"/>
                    <TextView
                        android:id="@+id/calorieText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 kcal"
                        android:layout_marginTop="8dp"
                        android:textStyle="bold"
                        android:textSize="18sp"/>
                    <TextView
                        android:text="Calories"
                        android:textSize="12sp"
                        android:textColor="#70757A"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/timeCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A1C2E"
            app:layout_constraintTop_toBottomOf="@id/statsContainer">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Target Duration"
                        android:textColor="#80FFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/timeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="00h 00m 00s"
                        android:textColor="#6366F1"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etHours"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="HH"
                        android:inputType="number"
                        android:maxLength="2"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#40FFFFFF"
                        android:textAlignment="center" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=":" android:textColor="#FFFFFF"/>

                    <EditText
                        android:id="@+id/etMinutes"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="MM"
                        android:inputType="number"
                        android:maxLength="2"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#40FFFFFF"
                        android:textAlignment="center" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=":" android:textColor="#FFFFFF"/>

                    <EditText
                        android:id="@+id/etSeconds"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="SS"
                        android:inputType="number"
                        android:maxLength="2"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#40FFFFFF"
                        android:textAlignment="center" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSetTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Set Goal"
                        android:textSize="12sp"
                        app:cornerRadius="10dp"
                        app:backgroundTint="#6366F1"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/resetBtn"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reset Statistics"
            android:textColor="#E11D48"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/timeCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>