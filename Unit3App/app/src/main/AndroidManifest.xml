<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Unit3App"
        tools:targetApi="31">
        <activity
            android:name=".TimePicker"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".DateAndTime"
            android:exported="true">

        </activity>
        <activity
            android:name=".MyFragment"
            android:exported="true"></activity>
        <activity
            android:name=".DateTimePicker"
            android:exported="true"></activity>
        <activity
            android:name=".MainActivity2"
            android:exported="true" />
        <activity
            android:name=".SenderFragment"
            android:exported="true"
            tools:ignore="Instantiatable" />
        <activity
            android:name=".ReceiverFragment"
            android:exported="true"
            tools:ignore="Instantiatable" />
        <activity
            android:name=".NavigationDrawer"
            android:exported="false" />
        <activity
            android:name=".ViewPager"
            android:exported="true" />
        <activity
            android:name=".Fragment2"
            android:exported="false"
            tools:ignore="Instantiatable" />
        <activity
            android:name=".Fragment1"
            android:exported="false"
            tools:ignore="Instantiatable" />
        <activity
            android:name=".MainActivity"
            android:exported="true" />

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />
    </application>

</manifest>