<?xml version="1.0" encoding="utf-8"?>
<!-- Onboarding Screen with ViewPager2, DotsIndicator, and animated navigation -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Gradient background -->
    <View
        android:id="@+id/bgGradient"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/onboarding_bg_gradient" />

    <!-- ViewPager2 for onboarding pages -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/dotsIndicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Dots Indicator -->
    <com.tbuonomo.viewpagerdotsindicator.DotsIndicator
        android:id="@+id/dotsIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:dotsColor="@color/accent_primary"
        app:dotsSize="8dp"
        app:dotsSpacing="6dp"
        app:selectedDotColor="@color/white"
        app:layout_constraintBottom_toTopOf="@id/btnSkip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp" />

    <!-- Skip Button -->
    <Button
        android:id="@+id/btnSkip"
        android:layout_width="120dp"
        android:layout_height="48dp"
        android:text="Skip"
        android:textColor="@color/white"
        android:background="@drawable/btn_outlined_rounded"
        android:fontFamily="@font/poppins_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="32dp"
        android:layout_marginBottom="48dp" />

    <!-- Next / Get Started Button -->
    <Button
        android:id="@+id/btnNext"
        android:layout_width="160dp"
        android:layout_height="52dp"
        android:text="Next"
        android:textColor="@color/bg_dark"
        android:background="@drawable/btn_gradient_rounded"
        android:fontFamily="@font/poppins_semibold"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="48dp" />

</androidx.constraintlayout.widget.ConstraintLayout>