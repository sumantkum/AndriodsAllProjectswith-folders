<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Sem8MyChatbot" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryVariant">@color/accent_secondary</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Status bar and navigation bar -->
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Typography -->
        <item name="textAppearanceBodyLarge">@style/TextAppearance.GeminiAI.Body</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.GeminiAI.Title</item>

        <!-- Shapes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.GeminiAI.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.GeminiAI.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.GeminiAI.Large</item>
    </style>

    <!-- Splash screen theme (fullscreen, no action bar) -->
    <style name="Theme.GeminiAI.Splash" parent="Theme.GeminiAI">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@color/bg_splash</item>
        <item name="android:navigationBarColor">@color/bg_splash</item>
    </style>

    <!-- ══════════════════════════════════════════════════ -->
    <!-- Typography                                        -->
    <!-- ══════════════════════════════════════════════════ -->

    <style name="TextAppearance.GeminiAI.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.GeminiAI.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- ══════════════════════════════════════════════════ -->
    <!-- Shapes                                            -->
    <!-- ══════════════════════════════════════════════════ -->

    <style name="ShapeAppearance.GeminiAI.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.GeminiAI.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.GeminiAI.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
</resources>