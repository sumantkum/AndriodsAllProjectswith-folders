<?xml version="1.0" encoding="utf-8"?>
<!-- Main Chat Screen Layout -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Animated gradient background layer -->
    <com.airbnb.lottie.LottieAnimationView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:lottie_rawRes="@raw/gradient_bg_animation"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        android:alpha="0.3" />

    <!-- Top Toolbar / Header -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:background="@drawable/toolbar_glass_bg"
        android:elevation="4dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="8dp">

            <!-- AI Avatar -->
            <ImageView
                android:id="@+id/imgAiAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_ai_avatar"
                android:background="@drawable/avatar_glow_bg"
                android:padding="6dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Chat title and status -->
            <LinearLayout
                android:id="@+id/layoutTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                app:layout_constraintStart_toEndOf="@id/imgAiAvatar"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnHistory">

                <TextView
                    android:id="@+id/tvChatTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New Chat"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Online"
                    android:textColor="@color/status_online"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

            <!-- History button -->
            <ImageButton
                android:id="@+id/btnHistory"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_history"
                android:background="@drawable/btn_icon_bg"
                android:tint="@color/white"
                android:padding="8dp"
                app:layout_constraintEnd_toStartOf="@id/btnSettings"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="8dp"
                android:contentDescription="Chat history" />

            <!-- Settings button -->
            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_settings"
                android:background="@drawable/btn_icon_bg"
                android:tint="@color/white"
                android:padding="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:contentDescription="Settings" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- Main content area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="68dp">

        <!-- Empty state (shown when no messages) -->
        <LinearLayout
            android:id="@+id/layoutEmptyState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="visible">

            <com.airbnb.lottie.LottieAnimationView
                android:layout_width="200dp"
                android:layout_height="200dp"
                app:lottie_rawRes="@raw/ai_idle_animation"
                app:lottie_autoPlay="true"
                app:lottie_loop="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ask me anything!"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="Start a conversation with Gemini AI. I can help with writing, coding, analysis, and much more."
                android:textColor="#80FFFFFF"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp" />

            <!-- Quick prompts -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPrompt1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✍️ Write"
                    android:textColor="@color/white"
                    android:background="@drawable/chip_glass_bg"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPrompt2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💻 Code"
                    android:textColor="@color/white"
                    android:background="@drawable/chip_glass_bg"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPrompt3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍 Research"
                    android:textColor="@color/white"
                    android:background="@drawable/chip_glass_bg" />

            </LinearLayout>
        </LinearLayout>

        <!-- Chat RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMessages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"
            android:clipToPadding="false"
            android:scrollbars="none"
            android:visibility="gone" />

        <!-- AI Typing Indicator -->
        <LinearLayout
            android:id="@+id/layoutTypingIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_ai_avatar"
                android:background="@drawable/avatar_small_bg" />

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/typingAnimation"
                android:layout_width="60dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                app:lottie_rawRes="@raw/typing_dots_animation"
                app:lottie_autoPlay="false"
                app:lottie_loop="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gemini is typing..."
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <!-- Bottom Input Area -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="4dp"
            app:cardBackgroundColor="@color/input_bg"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">

                <!-- Emoji button -->
                <ImageButton
                    android:id="@+id/btnEmoji"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_emoji"
                    android:background="@null"
                    android:tint="@color/icon_tint"
                    android:padding="4dp"
                    android:contentDescription="Emoji" />

                <!-- Message Input -->
                <EditText
                    android:id="@+id/etMessage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Ask anything..."
                    android:hintTextColor="@color/hint_color"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_regular"
                    android:background="@null"
                    android:maxLines="4"
                    android:inputType="textMultiLine|textCapSentences"
                    android:paddingHorizontal="8dp"
                    android:imeOptions="actionSend" />

                <!-- Voice input button (shown when empty) -->
                <ImageButton
                    android:id="@+id/btnVoice"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_mic"
                    android:background="@drawable/btn_gradient_circle"
                    android:tint="@color/white"
                    android:padding="10dp"
                    android:contentDescription="Voice input" />

                <!-- Send button (shown when text entered) -->
                <ImageButton
                    android:id="@+id/btnSend"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_send"
                    android:background="@drawable/btn_gradient_circle"
                    android:tint="@color/white"
                    android:padding="10dp"
                    android:visibility="gone"
                    android:contentDescription="Send message" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- New Chat FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabNewChat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_new_chat"
        app:backgroundTint="@color/accent_primary"
        app:tint="@color/white"
        app:fabSize="mini"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="96dp"
        android:elevation="8dp"
        android:contentDescription="New chat" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>